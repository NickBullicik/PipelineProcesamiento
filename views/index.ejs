<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recetario Universal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --naranja: #E8621A;
            --naranja-claro: #FFF3EC;
            --gris-oscuro: #1A1A1A;
            --gris-medio: #6B6B6B;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #FAFAFA;
            color: var(--gris-oscuro);
        }

        /* HEADER */
        .hero {
            background: var(--gris-oscuro);
            color: white;
            padding: 60px 0 40px;
        }

        .hero h1 {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            line-height: 1.1;
        }

        .hero h1 span { color: var(--naranja); }
        .hero p { color: #aaa; font-size: 1.1rem; }

        /* BADGE DE ROBOT */
        .robot-badge {
            display: inline-block;
            background: var(--naranja-claro);
            color: var(--naranja);
            border-radius: 20px;
            padding: 4px 12px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* CARDS */
        .receta-card {
            border: none;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            transition: transform 0.2s, box-shadow 0.2s;
            text-decoration: none;
            color: inherit;
            display: block;
            height: 100%;
            background: white;
        }

        .receta-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.13);
            color: inherit;
        }

        .receta-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .receta-card .card-body {
            padding: 20px;
        }

        .receta-card .card-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.05rem;
            margin-bottom: 10px;
            line-height: 1.3;
        }

        /* ETIQUETAS DE ALÉRGENOS */
        /* Cada alérgeno tiene su propio color para identificarlo de un vistazo */
        .alergeno {
            display: inline-block;
            border-radius: 10px;
            padding: 2px 8px;
            font-size: 0.7rem;
            font-weight: 600;
            margin: 2px 1px;
        }

        .alergeno-Gluten       { background: #FFF3CD; color: #856404; }
        .alergeno-Lactosa      { background: #D1ECF1; color: #0C5460; }
        .alergeno-Huevo        { background: #FDE8D8; color: #7B3F00; }
        .alergeno-Frutos-Secos { background: #D4EDDA; color: #155724; }
        .alergeno-Marisco      { background: #E8D5F5; color: #5B2C6F; }
        .alergeno-Pescado      { background: #D6EAF8; color: #1A5276; }
        .alergeno-Soja         { background: #FDFEFE; color: #555; border: 1px solid #ddd; }
        .alergeno-default      { background: #F0F0F0; color: #555; }

        /* TABLA NUTRICIONAL MINI en la card */
        .nutricion-mini {
            display: flex;
            gap: 8px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .nutri-pill {
            background: #F7F7F7;
            border-radius: 8px;
            padding: 3px 8px;
            font-size: 0.72rem;
            color: var(--gris-medio);
        }

        .nutri-pill strong {
            color: var(--gris-oscuro);
            font-weight: 600;
        }
    </style>
</head>
<body>

    <!-- HERO -->
    <div class="hero">
        <div class="container">
            <h1>Pipeline de<br><span>Procesamiento</span></h1>
            <p class="mt-3">Recetas adaptadas para tu robot de cocina, con información nutricional y alérgenos</p>
        </div>
    </div>

    <!-- GRID DE RECETAS -->
    <div class="container py-5">

        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="fw-bold mb-0" style="font-family:'Playfair Display',serif">Recetas disponibles</h2>
            <span class="badge bg-light text-dark border">
                <%= recetas.length %> receta<%= recetas.length !== 1 ? 's' : '' %>
            </span>
        </div>

        <div class="row g-4">
            <% recetas.forEach((receta, index) => { %>
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <a href="/receta/<%= index %>" class="receta-card">

                        <!-- IMAGEN -->
                        <img
                            src="<%= receta.imagen || 'https://placehold.co/400x200/f8f8f8/ccc?text=Sin+imagen' %>"
                            alt="<%= receta.titulo %>"
                            onerror="this.src='https://placehold.co/400x200/f8f8f8/ccc?text=Sin+imagen'"
                        >

                        <div class="card-body">

                            <!-- ROBOT ORIGINAL -->
                            <div class="robot-badge mb-2"><%= receta.robotOriginal %></div>

                            <!-- TÍTULO -->
                            <h3 class="card-title"><%= receta.titulo %></h3>

                            <!-- TIEMPO -->
                            <% if (receta.tiempoTotal) { %>
                                <small class="text-muted">⏱ <%= receta.tiempoTotal %></small>
                            <% } %>

                            <!-- ALÉRGENOS -->
                            <%
                                // Normalizamos el nombre del alérgeno para usar como clase CSS
                                // "Frutos Secos" → "Frutos-Secos"
                            %>
                            <% if (receta.alergenos && receta.alergenos.length > 0) { %>
                                <div class="mt-2">
                                    <% receta.alergenos.forEach(alergeno => { %>
                                        <%
                                            const claseAlergeno = alergeno.replace(/ /g, '-');
                                            const tieneClase = ['Gluten','Lactosa','Huevo','Frutos-Secos','Marisco','Pescado','Soja'].includes(claseAlergeno);
                                        %>
                                        <span class="alergeno alergeno-<%= tieneClase ? claseAlergeno : 'default' %>">
                                            ⚠️ <%= alergeno %>
                                        </span>
                                    <% }) %>
                                </div>
                            <% } %>

                            <!-- NUTRICIÓN MINI -->
                            <% if (receta.nutricion) { %>
                                <div class="nutricion-mini">
                                    <span class="nutri-pill"><strong><%= receta.nutricion.calorias %></strong> kcal</span>
                                    <span class="nutri-pill"><strong><%= receta.nutricion.proteinas %>g</strong> prot</span>
                                    <span class="nutri-pill"><strong><%= receta.nutricion.hidratos %>g</strong> HC</span>
                                </div>
                            <% } %>

                        </div>
                    </a>
                </div>
            <% }) %>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>